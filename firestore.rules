rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    function validLeadCreate() {
      return request.resource.data.keys().hasAll(['formType', 'data', 'status', 'createdAt'])
        && request.resource.data.status == 'new'
        && request.resource.data.formType is string
        && request.resource.data.data is map;
    }

    // Public content
    match /projects/{id} {
      allow read: if resource.data.status == 'published' || isAdmin();
      allow write: if isAdmin();
    }

    match /services/{id} {
      allow read: if resource.data.status == 'published' || isAdmin();
      allow write: if isAdmin();
    }

    match /testimonials/{id} {
      allow read: if resource.data.approved == true || isAdmin();
      allow write: if isAdmin();
    }

    match /journal/{id} {
      allow read: if resource.data.status == 'published' || isAdmin();
      allow write: if isAdmin();
    }

    match /settings/{id} {
      allow read;
      allow write: if isAdmin();
    }

    // Leads: public can create (bounded), only admins can read/update/delete
    match /leads/{id} {
      allow create: if validLeadCreate();
      allow read, update, delete: if isAdmin();
    }

    match /users/{uid} {
      allow read: if isAdmin() || request.auth.uid == uid;
      allow write: if isAdmin();
    }
  }
}
